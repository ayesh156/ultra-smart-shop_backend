# ===================================================
# Ultra Smart Shop — Environment Configuration
# ===================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control!
# ===================================================

# ─── Environment ───────────────────────────────────
# "development" for local, "production" for VPS/server
NODE_ENV=development
PORT=3001

# ─── Database (MySQL) ─────────────────────────────
# Local:      mysql://root:password@localhost:3306/ultra_smart_shop
# VPS:        mysql://uss_user:STRONG_PASS@localhost:3306/ultra_smart_shop
DATABASE_URL="mysql://root:your_password@localhost:3306/ultra_smart_shop"

# ─── JWT Secrets ──────────────────────────────────
# Generate strong secrets: openssl rand -hex 48
JWT_SECRET=change-this-to-a-strong-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-this-to-another-strong-secret-at-least-32-chars

# ─── Token Expiry ─────────────────────────────────
# Supported: 15m, 1h, 7d, 30d
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# ─── CORS / Frontend URL ─────────────────────────
# Local dev:   http://localhost:5173
# Production:  https://yourdomain.com  (or leave empty if serving from same origin)
FRONTEND_URL=http://localhost:5173
